# Database (remote MySQL — leave blank and set LOCAL_DB=true for development)
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

# Set to true to use local SQLite DB instead of remote MySQL (for development)
LOCAL_DB=true

# Server ports
PORT=5000
FLASK_PORT=5001

# REQUIRED: Set a strong random secret for JWT signing (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
JWT_SECRET=

# REQUIRED: Admin password for product management
ADMIN_PASSWORD=

# M-Pesa / Daraja API credentials
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=

# Google OAuth
GOOGLE_CLIENT_ID=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Gemini AI
GEMINI_API_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to true only in development
FLASK_DEBUG=false
